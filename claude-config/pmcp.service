[Unit]
Description=PMCP MCP Gateway (shared HTTP service for coding agents)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-%h/.config/pmcp/pmcp.env
ExecStart=%h/.local/bin/pmcp -c %h/.pmcp.json --transport http --host 127.0.0.1 --port 3344 -l info
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
