# Secrets - never commit
.env
.env.*
!.env.example
*.secret
*credentials*
*token*
*.key
*.pem

# MCP config (contains API keys)
.mcp.json
!.mcp.json.example

# PMCP gateway runtime files
.pmcp/logs/
.mcp-gateway/gateway.lock

# Claude Code state (not config)
.credentials.json

# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Python bytecode
__pycache__/
*.pyc

# Skill close-out artifacts (per-skill, generated each run)
claude-config/skills/*/reflections/
claude-config/skills/*/handoff.md

# Generated plan output (skill-improvement-planner)
claude-config/skills/*/plans/
